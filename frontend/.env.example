# =========================================================================
# EFFORTLESS ENGLISH - FRONTEND ENVIRONMENT VARIABLES EXAMPLE
# =========================================================================
# Since this is an Angular project, these variables are typically used
# by build scripts or manual configuration in src/environments/
# -------------------------------------------------------------------------

# The URL where your NestJS backend is running
API_URL="http://localhost:3000"

# Supabase Public Keys (Used for Authentication and Database access)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Application Settings
FRONTEND_PORT=4200
