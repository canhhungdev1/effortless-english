// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String?
  avatar     String?
  role       Role     @default(USER)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  vocabularies UserVocabulary[]
  review_history ReviewHistory[]

  @@map("users")
}

model Course {
  id          String   @id @default(uuid())
  slug        String   @unique @default("")
  title       String
  description String?
  level       String?
  cover_image String?  @map("cover_image")
  is_vip      Boolean  @default(false) @map("is_vip")
  stage       Int      @default(1)
  order       Int      @default(0)
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @updatedAt @map("updated_at")


  lessons Lesson[]

  @@map("courses")
}

model Lesson {
  id         String   @id @default(uuid())
  course_id  String   @map("course_id")
  slug       String @default("")
  order      Int      @default(0)
  title      String
  progress   Int      @default(0)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  course   Course          @relation(fields: [course_id], references: [id], onDelete: Cascade)
  contents LessonContent[]

  @@unique([course_id, slug])
  @@map("lessons")
}

model LessonContent {
  id         String   @id @default(uuid())
  lesson_id  String   @map("lesson_id")
  type       String   // ARTICLE, VOCABULARY, MINI_STORY, POINT_OF_VIEW, COMMENTARY
  title      String?  @map("title")
  audio_url  String?  @map("audio_url")
  vtt_url    String?  @map("vtt_url")
  content_en String?  @map("content_en") // English text for Article
  content_vi String?  @map("content_vi") // Vietnamese text for Article
  data       Json?    // paragraphs, keywords, story lines, etc.
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@map("lesson_contents")
}

model UserVocabulary {
  id              String   @id @default(uuid())
  user_id         String   @map("user_id")
  word            String
  translation     String
  phonetic        String?
  audio           String?
  example         String?
  
  // SRS Fields (SM-2 Algorithm)
  interval        Int      @default(0)    // In days
  repetitions     Int      @default(0)    
  ease_factor     Float    @default(2.5)  
  next_review     DateTime @default(now()) @map("next_review")
  is_favorite     Boolean  @default(false) @map("is_favorite")
  
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  review_history  ReviewHistory[]

  @@unique([user_id, word])
  @@map("user_vocabulary")
}

model ReviewHistory {
  id              String   @id @default(uuid())
  user_id         String   @map("user_id")
  vocabulary_id   String   @map("vocabulary_id")
  rating          Int      // 0-3 (Again, Hard, Good, Easy)
  created_at      DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vocabulary      UserVocabulary @relation(fields: [vocabulary_id], references: [id], onDelete: Cascade)

  @@map("review_history")
}
