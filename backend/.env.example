# Database Connection (Supabase/PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?schema=public"

# Application Settings
PORT=3000

# Supabase Configuration (if needed for backend)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Storage Configuration
# Absolute path to external storage directory (outside project root)
# Example: E:/Workspace/MyProject/Storage/effortless-english-storage
MEDIA_PATH=

