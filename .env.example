# =========================================================================
# EFFORTLESS ENGLISH - ENVIRONMENT VARIABLES EXAMPLE
# =========================================================================
# This file serves as a template for your local environment configuration.
# Copy this file to .env and fill in the actual values.
# DO NOT commit the .env file to version control.

# -------------------------------------------------------------------------
# BACKEND SETTINGS (NestJS)
# -------------------------------------------------------------------------
BACKEND_PORT=3000

# Database Connection (Supabase/PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?schema=public"

# -------------------------------------------------------------------------
# SUPABASE SETTINGS (Used by both Frontend & Backend)
# -------------------------------------------------------------------------
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# -------------------------------------------------------------------------
# FRONTEND SETTINGS (Angular)
# -------------------------------------------------------------------------
FRONTEND_PORT=4200
API_URL="http://localhost:3000"
